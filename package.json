{
  "name": "@tb-dev/eslint-config",
  "version": "10.0.9",
  "description": "ESLint config",
  "license": "MIT",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@11.0.4",
  "funding": "https://github.com/sponsors/ferreira-tb",
  "homepage": "https://github.com/ferreira-tb/eslint-config",
  "repository": {
    "type": "git",
    "url": "https://github.com/ferreira-tb/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/ferreira-tb/eslint-config/issues"
  },
  "keywords": ["eslint", "eslint-config"],
  "scripts": {
    "build": "vite build",
    "format": "dprint fmt",
    "lint": "eslint . --config eslint.config.js",
    "release": "pnpm run build && pnpm publish",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "unplugin-dts": "^1.0.0",
    "vite": "^8.0.10"
  },
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
